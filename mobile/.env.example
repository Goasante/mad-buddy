# Copy to .env.local and fill in. All values are PUBLIC (shipped in the bundle),
# so only use the anon/publishable Supabase key — never the service role key.

# The deployed web app that hosts the /api/* route handlers the SPA calls.
VITE_API_BASE_URL=https://mad-buddy.vercel.app

# Supabase project (same project as the web app).
VITE_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR-ANON-OR-PUBLISHABLE-KEY
